	/* Configure the system clock */
	SystemClock_Config();

	/* USER CODE BEGIN SysInit */

	/* USER CODE END SysInit */

	/* Initialize all configured peripherals */
	MX_GPIO_Init();
	MX_I2C2_Init();
	/* USER CODE BEGIN 2 */
	HAL_I2C_EnableListen_IT( &hi2c2 );
	/* USER CODE END 2 */

	/* Infinite loop */
	/* USER CODE BEGIN WHILE */
	while (1)
	{
		/* USER CODE END WHILE */

		/* USER CODE BEGIN 3 */
		for( y = 0; y < 11; y++ ) {
			HAL_GPIO_WritePin( GPIOB, gpio_y[y], GPIO_PIN_RESET );
			msx_key_matrix[y] = LL_GPIO_ReadInputPort( GPIOA ) & 0xFF;
			HAL_GPIO_WritePin( GPIOB, gpio_y[y], GPIO_PIN_SET );
		}
		HAL_Delay( 4 );
	}
	/* USER CODE END 3 */
}

