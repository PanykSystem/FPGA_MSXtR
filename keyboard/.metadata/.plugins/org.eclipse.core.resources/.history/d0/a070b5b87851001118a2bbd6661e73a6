// アドレス一致時に呼ばれる
void HAL_I2C_AddrCallback( I2C_HandleTypeDef *hi2c, uint8_t TransferDirection, uint16_t AddrMatchCode ) {
	// TransferDirectionの意味（重要！）
	// I2C_DIRECTION_TRANSMIT	 → マスタがデータを送ってくる（スレーブは受信モード）
	// I2C_DIRECTION_RECEIVE	 → マスタがデータを要求（スレーブは送信モード）

	if( TransferDirection == I2C_DIRECTION_TRANSMIT ) {
		// マスタ → スレーブ（Write） → 受信開始
		HAL_I2C_Slave_Seq_Receive_IT( hi2c, rx_buffer, 1, I2C_FIRST_AND_LAST_FRAME );
	}
	else
	{
		// マスタ ← スレーブ（Read） → 送信開始
		HAL_I2C_Slave_Seq_Transmit_IT( hi2c, tx_buffer, 12, I2C_FIRST_AND_LAST_FRAME );
	}
}

// 受信完了時に呼ばれる
void HAL_I2C_SlaveRxCpltCallback(I2C_HandleTypeDef *hi2c) {
	uint8_t data = rx_buffer[0];
	// HAL_GPIO_WritePin( LED0_GPIO_Port, LED0_Pin, (data & 0x01) ? GPIO_PIN_RESET : GPIO_PIN_SET );
	// HAL_GPIO_WritePin( LED1_GPIO_Port, LED1_Pin, (data & 0x02) ? GPIO_PIN_RESET : GPIO_PIN_SET );
	// HAL_GPIO_WritePin( LED2_GPIO_Port, LED2_Pin, (data & 0x04) ? GPIO_PIN_RESET : GPIO_PIN_SET );

	//	★デバッグ
	HAL_GPIO_WritePin( LED0_GPIO_Port, LED0_Pin, GPIO_PIN_RESET );
	HAL_GPIO_WritePin( LED1_GPIO_Port, LED1_Pin, GPIO_PIN_SET );
	HAL_GPIO_WritePin( LED2_GPIO_Port, LED2_Pin, GPIO_PIN_SET );

	// msx_key_matrix の内容を tx_buffer に格納（次のマスター読み出しで返す）
	for( int i = 0; i < 12; i++ ) {
		tx_buffer[i] = (uint8_t)msx_key_matrix[i];
	}
}

