  LUT3 n126_s0 (
    .F(n126_3),
    .I0(ff_bus_wdata[4]),
    .I1(ff_data[7]),
    .I2(n133_7) 
);
defparam n126_s0.INIT=8'hCA;
  LUT3 n127_s0 (
    .F(n127_3),
    .I0(ff_bus_wdata[3]),
    .I1(ff_data[6]),
    .I2(n133_7) 
);
defparam n127_s0.INIT=8'hCA;
  LUT3 n128_s0 (
    .F(n128_3),
    .I0(ff_bus_wdata[2]),
    .I1(ff_data[5]),
    .I2(n133_7) 
);
defparam n128_s0.INIT=8'hCA;
  LUT3 n129_s0 (
    .F(n129_3),
    .I0(ff_bus_wdata[1]),
    .I1(ff_data[4]),
