module ip_uart (
  clk27m_d,
  ff_uart_valid1,
  ff_reset_n1,
  ff_bus_wdata,
  uart_tx_d,
  w_ready
)
;
input clk27m_d;
input ff_uart_valid1;
input ff_reset_n1;
input [7:0] ff_bus_wdata;
output uart_tx_d;
output w_ready;
wire n192_3;
wire n80_3;
wire n91_3;
wire n124_3;
wire n125_3;
wire n126_3;
wire n127_3;
wire n128_3;
wire n129_3;
wire n130_3;
wire n131_7;
wire n121_7;
wire n120_7;
