wire GND;
  LUT4 n192_s0 (
    .F(n192_3),
    .I0(n133_7),
    .I1(ff_uart_valid1),
    .I2(n192_4),
    .I3(ff_reset_n1) 
);
defparam n192_s0.INIT=16'hF4FF;
  LUT3 n80_s0 (
    .F(n80_3),
    .I0(n192_4),
