  LUT4 n91_s0 (
    .F(n91_3),
    .I0(ff_uart_valid1),
    .I1(n192_4),
    .I2(ff_state[3]),
    .I3(n91_4) 
);
defparam n91_s0.INIT=16'hC00A;
  LUT3 n124_s0 (
    .F(n124_3),
    .I0(ff_bus_wdata[6]),
    .I1(ff_data[9]),
    .I2(n133_7) 
);
