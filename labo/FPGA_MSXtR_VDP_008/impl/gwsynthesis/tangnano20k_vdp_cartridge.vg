  LUT2 n131_s2 (
    .F(n131_7),
    .I0(ff_data[2]),
    .I1(n133_7) 
);
defparam n131_s2.INIT=4'h8;
  LUT4 n121_s2 (
    .F(n121_7),
    .I0(ff_state[2]),
    .I1(ff_state[3]),
    .I2(ff_state[0]),
    .I3(ff_state[1]) 
);
