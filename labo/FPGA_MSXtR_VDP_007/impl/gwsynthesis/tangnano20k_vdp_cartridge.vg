  pa_en,
  i2s_bclk,
  i2s_lrck,
  i2s_din,
  intr,
  ws2812,
  uart_tx,
  dipsw,
  led,
  tmds_clk_p,
  tmds_clk_n,
  tmds_d_p,
  tmds_d_n,
  O_sdram_clk,
