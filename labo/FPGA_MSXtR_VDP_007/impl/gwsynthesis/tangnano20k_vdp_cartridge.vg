module ip_uart (
  clk27m_d,
  ff_uart_valid1,
  ff_reset_n1,
  ff_bus_wdata,
  uart_tx_d,
  w_ready
)
;
input clk27m_d;
input ff_uart_valid1;
input ff_reset_n1;
input [7:0] ff_bus_wdata;
output uart_tx_d;
output w_ready;
wire n192_3;
wire n80_3;
wire n91_3;
wire n124_3;
wire n125_3;
wire n126_3;
wire n127_3;
wire n128_3;
wire n129_3;
wire n130_3;
wire n131_7;
wire n121_7;
wire n120_7;
wire n119_7;
wire n133_7;
wire n132_6;
wire n123_7;
wire n122_6;
wire n52_6;
wire n49_6;
wire n47_6;
wire n46_6;
wire n45_6;
wire n20_10;
wire n19_10;
wire n17_10;
wire n13_10;
wire n12_8;
wire n192_4;
wire n91_4;
wire n49_7;
wire n47_7;
wire n47_8;
wire n46_7;
wire n45_7;
wire n55_5;
wire [9:0] ff_uart_count;
wire [3:0] ff_state;
wire [9:1] ff_data;
wire VCC;
wire GND;
  LUT4 n192_s0 (
    .F(n192_3),
    .I0(n133_7),
    .I1(ff_uart_valid1),
    .I2(n192_4),
    .I3(ff_reset_n1) 
);
defparam n192_s0.INIT=16'hF4FF;
  LUT3 n80_s0 (
    .F(n80_3),
    .I0(n192_4),
    .I1(ff_uart_valid1),
    .I2(n133_7) 
);
defparam n80_s0.INIT=8'hAC;
  LUT4 n91_s0 (
    .F(n91_3),
    .I0(ff_uart_valid1),
    .I1(n192_4),
    .I2(ff_state[3]),
    .I3(n91_4) 
);
defparam n91_s0.INIT=16'hC00A;
  LUT3 n124_s0 (
    .F(n124_3),
    .I0(ff_bus_wdata[6]),
    .I1(ff_data[9]),
    .I2(n133_7) 
);
defparam n124_s0.INIT=8'hCA;
  LUT3 n125_s0 (
    .F(n125_3),
    .I0(ff_bus_wdata[5]),
    .I1(ff_data[8]),
