module tangnano20k_vdp_cartridge (
  clk27m,
  clk14m,
  button,
  vdp_so_clk,
  vdp_so,
  vdp_si_clk,
  vdp_si,
  spi_cs_n,
  spi_clk,
  spi_mosi,
  spi_miso,
  spi_intr,
  pa_en,
  i2s_bclk,
  i2s_lrck,
  i2s_din,
  intr,
  ws2812,
  uart_tx,
  dipsw,
  led,
  tmds_clk_p,
  tmds_clk_n,
  tmds_d_p,
  tmds_d_n,
  O_sdram_clk,
  O_sdram_cke,
  O_sdram_cs_n,
  O_sdram_ras_n,
  O_sdram_cas_n,
  O_sdram_wen_n,
  IO_sdram_dq,
  O_sdram_addr,
  O_sdram_ba,
  O_sdram_dqm
)
;
input clk27m;
input clk14m;
input [1:0] button;
output vdp_so_clk;
output [1:0] vdp_so;
input vdp_si_clk;
input [1:0] vdp_si;
input spi_cs_n;
input spi_clk;
input spi_mosi;
output spi_miso;
output spi_intr;
output pa_en;
input i2s_bclk;
input i2s_lrck;
input i2s_din;
output intr;
output ws2812;
output uart_tx;
input dipsw;
output led;
output tmds_clk_p;
output tmds_clk_n;
output [2:0] tmds_d_p;
output [2:0] tmds_d_n;
output O_sdram_clk;
output O_sdram_cke;
output O_sdram_cs_n;
output O_sdram_ras_n;
output O_sdram_cas_n;
output O_sdram_wen_n;
inout [31:0] IO_sdram_dq;
output [10:0] O_sdram_addr;
output [1:0] O_sdram_ba;
output [3:0] O_sdram_dqm;
