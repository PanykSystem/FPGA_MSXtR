    .BLKSEL({GND,GND,GND}),
    .AD({w_bus_address[9:0],GND,GND,GND,GND}),
    .WRE(w_we),
    .CLK(clk42m),
    .CE(w_ram_cs),
    .OCE(w_re),
    .RESET(n24_11) 
);
